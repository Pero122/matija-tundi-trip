# TripAdvisor raw pages and generated datasets stay local. Keep the small,
# repeatable crawler pipeline and its tests in version control.
budapest-london/tripadvisor/*
!budapest-london/tripadvisor/index.html
!budapest-london/tripadvisor/supabase_setup.sql
!budapest-london/tripadvisor/scrape_ta.py
